# Azure AI Services
AISERVICES_COGNITIVE_SERVICES_ENDPOINT=https://ais-ocm20-obe-dev-001.cognitiveservices.azure.com/

# Application Insights
#APPINSIGHTS_CONNECTION_STRING="InstrumentationKey=dfc5f9de-9dba-432b-93df-dd0a3cae0b17;IngestionEndpoint=https://eastus2-3.in.applicationinsights.azure.com/;LiveEndpoint=https://eastus2.livediagnostics.monitor.azure.com/;ApplicationId=5527ef64-d128-41e3-886b-1dbfb3603d3e"
# Azure OpenAI
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_CHAT_COMPLETION_RESOURCE_URI=https://aif-ocm20-obe-dev-001.openai.azure.com/openai/deployments/gpt-5.1-ocm20-obe-dev-001/chat/completions?api-version=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.1-ocm20-obe-dev-001
AZURE_OPENAI_ENDPOINT=https://aif-ocm20-obe-dev-001.openai.azure.com/
AZURE_OPENAI_MAX_CONTEXT_TOKENS=128000
AZURE_OPENAI_MAX_TOKENS=4096
AZURE_OPENAI_TEMPERATURE=0.0
AZURE_OPENAI_TEXT_EMBEDDING_MODEL=text-embedding-3-large


# Blob Storage
BLOBSTORAGE_CONTAINER_NAME=ka-2-sharepoinr-tags
BLOBSTORAGE_IMAGES_CONTAINER_NAME=ka-2-sharepoinr-tags-images
BLOBSTORAGE_RESOURCE_ID=/subscriptions/7b2f5ca9-5d55-4ff0-abc9-fea4aac92490/resourceGroups/rg-ocm20_obe-dev-001/providers/Microsoft.Storage/storageAccounts/saocm20obedev001

# Cosmos DB
COSMOS_CONTAINER_NAME=conversations
COSMOS_DATABASE_NAME=agentic_rag
COSMOS_DEFAULT_TTL_DAYS=30
COSMOS_ENABLE_TTL=true
COSMOS_ENDPOINT=https://cosmosdb-ka-dev-001.documents.azure.com:443/

# Environment
ENABLE_SENSITIVE_DATA=true
ENVIRONMENT=production
USE_MANAGED_IDENTITY=true

# Foundry Project
FOUNDRY_PROJECT_ENDPOINT=https://aif-ocm20-obe-dev-001.services.ai.azure.com/api/projects/aif-proj-ocm20_obe-dev-001

# Deployment
SCM_DO_BUILD_DURING_DEPLOYMENT=1
WEBSITE_HEALTHCHECK_MAXPINGFAILURES=10

# Search Service
SEARCHSERVICE_API_KEY=yH5FzgVBVexIYWehw3R9cWErhOzw3yIPLtmQVPxU13AzSeCORbad
SEARCHSERVICE_DATA_SOURCE_NAME=-datasource
SEARCHSERVICE_ENDPOINT=https://search-ocmka20-dev.search.windows.net
SEARCHSERVICE_INDEX_NAME=ka-2-sharepoinr-tags-index
SEARCHSERVICE_INDEXER_NAME=ka-2-sharepoinr-tags-indexer
SEARCHSERVICE_SKILLSET_API_VERSION=2025-08-01-preview
SEARCHSERVICE_SKILLSET_NAME=ka-2-sharepoinr-tags-skillset

# --- French-Canadian Search resource names ---
SEARCHSERVICE_INDEX_NAME_FR=evolve-index-fr
SEARCHSERVICE_DATA_SOURCE_NAME_FR=evolve-data-source-fr
SEARCHSERVICE_SKILLSET_NAME_FR=evolve-skillset-fr
SEARCHSERVICE_INDEXER_NAME_FR=evolve-indexer-fr

# --- French-Canadian Blob containers ---
BLOBSTORAGE_CONTAINER_NAME_FR=documents-fr
BLOBSTORAGE_IMAGES_CONTAINER_NAME_FR=normalized-images-fr

# --- Default language when API request omits it ---
DEFAULT_LANGUAGE=en

# Workflow
WORKFLOW_CONVERSATION_HISTORY_WINDOW=5
WORKFLOW_ENABLE_QUERY_REWRITING=true
WORKFLOW_ENABLE_REFLECTION=true
WORKFLOW_MAX_RETRIEVAL_ITERATIONS=2